# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_api_key_here

# SQLite database path (optional, defaults to ./engram.db)
ENGRAM_DB_PATH=./engram.db

# Max tokens before compression is triggered (optional, default 4000)
ENGRAM_MAX_TOKENS=4000

# PostgreSQL connection (optional, only needed if using postgres storage)
PGHOST=localhost
PGPORT=5432
PGDATABASE=engram
PGUSER=postgres
PGPASSWORD=
